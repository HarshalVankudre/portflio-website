# Chat route — Groq LLM (used by /api/chat).
# Optional: without it the assistant streams grounded fallback answers.
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant

# Contact form email via Resend (used by /api/send).
# RESEND_FROM_EMAIL must be a verified sender/domain in production —
# the onboarding@resend.dev fallback has degraded deliverability.
RESEND_API_KEY=
RESEND_FROM_EMAIL=Portfolio Contact <onboarding@resend.dev>
RESEND_TO_EMAIL=harshalvankudre@gmail.com

# Public site URL, e.g. https://vankudre.com — used for metadata/sitemap/robots
NEXT_PUBLIC_SITE_URL=
