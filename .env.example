# Chat route — Groq LLM (used by /api/chat)
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant

# Contact form email via Resend (used by /api/send)
RESEND_API_KEY=
RESEND_FROM_EMAIL=Portfolio Contact <onboarding@resend.dev>
RESEND_TO_EMAIL=harshalvankudre@gmail.com

# GitHub GraphQL for real contribution data (used by /api/github).
# Without it the GitHub section hides contribution stats.
GITHUB_TOKEN=

# Public site URL, e.g. https://vankudre.com — used for metadata/sitemap/robots
NEXT_PUBLIC_SITE_URL=
